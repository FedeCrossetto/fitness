{
  "name": "reset-fitness-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/mobile",
    "dev:android": "npm run dev:android --workspace apps/mobile",
    "dev:device": "npm run dev:device --workspace apps/mobile",
    "metro": "npm run metro --workspace apps/mobile",
    "mobile": "npm run dev --workspace apps/mobile",
    "mobile:ios": "npm run dev --workspace apps/mobile",
    "mobile:android": "npm run dev:android --workspace apps/mobile",
    "web": "npm run dev --workspace apps/web",
    "web:build": "npm run build --workspace apps/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace @reset-fitness/shared"
  },
  "dependencies": {
    "expo-local-authentication": "~17.0.8"
  }
}
